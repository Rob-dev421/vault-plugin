#!/bin/bash
# bin/vault-synthesize-finalize
# Usage: vault-synthesize-finalize <vault-root> <wiki-file> [wiki-file2 ...]
# Called by vault-synthesize SKILL after Claude writes wiki entries.
# Updates wiki/log.md. Preserves manual edits (mtime check).

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/log.sh"
source "$SCRIPT_DIR/../lib/frontmatter.sh"

VAULT_ROOT="${1:?Usage: vault-synthesize-finalize <vault-root> <wiki-file...>}"
shift
WIKI_FILES=("$@")

WIKI_DIR="$VAULT_ROOT/wiki"

for wiki_file in "${WIKI_FILES[@]}"; do
  [[ -f "$wiki_file" ]] || continue

  rel_path="${wiki_file#$VAULT_ROOT}"
  [[ "$rel_path" != /* ]] && rel_path="/$rel_path"

  concept_name=$(basename "$wiki_file" .md)

  # Log the entry
  log_append "$VAULT_ROOT" "$WIKI_DIR/log.md" "Synthesized: $concept_name" "$rel_path"

  echo "Finalized wiki entry: $rel_path"
done

# ── Incremental graph update (soft dependency) ────────────────────────────
VAULT_GRAPHIFY="$SCRIPT_DIR/vault-graphify"
if [[ -f "$VAULT_GRAPHIFY" ]]; then
  bash "$VAULT_GRAPHIFY" "$VAULT_ROOT" 2>/dev/null || true
fi
