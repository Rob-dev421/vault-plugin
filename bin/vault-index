#!/bin/bash
# bin/vault-index
# Usage: vault-index <vault-root> [<directory>]
# Regenerates index.md for a directory (or all directories in the vault).

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/index.sh"

VAULT_ROOT="${1:-$HOME/vault}"
TARGET="${2:-$VAULT_ROOT}"

regenerate_index() {
  local dir="$1"
  local is_root=false
  [[ "$dir" -ef "$VAULT_ROOT" ]] && is_root=true

  local content
  content=$(index_for_dir "$dir" "$is_root")
  echo "$content" > "$dir/index.md"
}

if [[ -d "$TARGET" ]]; then
  # Regenerate for target dir and all subdirs that contain .md files
  while IFS= read -r -d '' dir; do
    # Skip engine/ directory and hidden dirs
    [[ "$dir" == *"/engine"* ]] && continue
    [[ "$dir" == *"/."* ]] && continue
    # Only regenerate if dir contains .md files (besides index.md itself)
    has_md=$(find "$dir" -maxdepth 1 -name "*.md" -not -name "index.md" | head -1)
    [[ -n "$has_md" ]] && regenerate_index "$dir"
  done < <(find "$TARGET" -type d -print0 | sort -z)
  # Always regenerate vault root index
  regenerate_index "$VAULT_ROOT"
fi

echo "Index regenerated for $TARGET"
