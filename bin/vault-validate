#!/bin/bash
# bin/vault-validate
# Usage: vault-validate <path>
# Runs OKF conformance check and outputs a structured report.
# Exit: 0 = no errors; 1 = errors found

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_VALIDATE="$SCRIPT_DIR/../lib/validate.sh"
STATE_FILE=""

# Parse args
TARGET="${1:-.}"
shift || true
while [[ $# -gt 0 ]]; do
  case "$1" in
    *) shift ;;
  esac
done

# Locate .vault-state.json if we're in a vault
if [[ -f "$TARGET/.vault" || -f "$TARGET/../.vault" ]]; then
  VAULT_ROOT="$TARGET"
  [[ -f "$TARGET/../.vault" ]] && VAULT_ROOT="$(cd "$TARGET/.." && pwd)"
  STATE_FILE="$VAULT_ROOT/.vault-state.json"
fi

# Run validation and capture output
raw_output=$(bash "$LIB_VALIDATE" "$TARGET" 2>&1) || true
validate_exit=$?

# Count findings by severity
error_count=$(echo "$raw_output" | grep -c "^ERROR" 2>/dev/null || true)
warn_count=$(echo "$raw_output" | grep -c "^WARNING" 2>/dev/null || true)
[[ -z "$raw_output" ]] && error_count=0 && warn_count=0

# Format structured report
echo "# OKF Validation Report"
echo ""
echo "## Summary"
echo ""
echo "- Errors: $error_count"
echo "- Warnings: $warn_count"
echo "- Path: $TARGET"
echo ""

if [[ -n "$raw_output" ]]; then
  errors=$(echo "$raw_output" | grep "^ERROR" || true)
  warnings=$(echo "$raw_output" | grep "^WARNING" || true)

  echo "## Errors"
  echo ""
  if [[ -n "$errors" ]]; then
    echo "$errors" | while IFS= read -r line; do echo "- $line"; done
  else
    echo "_None_"
  fi
  echo ""

  echo "## Warnings"
  echo ""
  if [[ -n "$warnings" ]]; then
    echo "$warnings" | while IFS= read -r line; do echo "- $line"; done
  else
    echo "_None_"
  fi
  echo ""

  echo "## Recommendations"
  echo ""
  if [[ $error_count -gt 0 ]]; then
    echo "- Fix all ERROR findings before committing or sharing this vault."
  else
    echo "- Vault is conformant with OKF v0.1."
  fi
else
  echo "## Errors"
  echo ""
  echo "_None_"
  echo ""
  echo "## Warnings"
  echo ""
  echo "_None_"
  echo ""
  echo "## Recommendations"
  echo ""
  echo "- Vault is conformant with OKF v0.1."
fi

# Write last-run timestamp to .vault-state.json
if [[ -n "$STATE_FILE" ]]; then
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  py -3 - "$STATE_FILE" "$timestamp" <<'PYEOF' 2>/dev/null || true
import json, sys, os
f, ts = sys.argv[1], sys.argv[2]
d = json.load(open(f)) if os.path.isfile(f) else {}
d['last_validate'] = ts
json.dump(d, open(f, 'w'), indent=2)
PYEOF
fi

# 0 errors on valid vault → 0 errors reported → report says "0 errors"
[[ $error_count -eq 0 ]]
