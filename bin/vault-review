#!/bin/bash
# bin/vault-review
# Usage: vault-review <vault-root>
# Reads changed file list from stdin (one path per line, relative to vault root).
# Validates contribution before merge/commit. Exits 0 if clean, 1 if issues found.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/frontmatter.sh"

VAULT_ROOT="${1:-$HOME/vault}"

issues=()
warnings=()
files_checked=0

while IFS= read -r rel_file; do
  [[ -z "$rel_file" ]] && continue
  abs_file="$VAULT_ROOT/$rel_file"
  [[ ! -f "$abs_file" ]] && continue
  [[ "$abs_file" != *.md ]] && continue

  files_checked=$((files_checked + 1))
  fname=$(basename "$abs_file")

  # Skip reserved files
  [[ "$fname" == "index.md" || "$fname" == "log.md" || "$fname" == "transcript.md" ]] && continue

  # Determine layer from path
  layer=""
  [[ "$rel_file" == sources/* ]] && layer="sources"
  [[ "$rel_file" == wiki/* ]]    && layer="wiki"

  # ── Source file: must have derived_from ──────────────────────────────────
  if [[ "$layer" == "sources" ]]; then
    derived=$(get_field "$abs_file" "derived_from" 2>/dev/null || true)
    if [[ -z "$derived" ]]; then
      issues+=("ERROR: $rel_file — source concept missing 'derived_from' field")
    fi
  fi

  # ── Wiki file: must have a source link ───────────────────────────────────
  if [[ "$layer" == "wiki" ]]; then
    has_source_link=$(grep -c "/sources/" "$abs_file" 2>/dev/null || echo "0")
    if [[ "$has_source_link" -eq 0 ]]; then
      issues+=("ERROR: $rel_file — wiki entry has no link to a source concept")
    fi
  fi

done

# ── Report ────────────────────────────────────────────────────────────────
if [[ $files_checked -eq 0 ]]; then
  echo "vault-review: no .md files to review"
  exit 0
fi

if [[ ${#issues[@]} -eq 0 ]]; then
  echo "vault-review passed: $files_checked file(s) reviewed, no issues found"
  exit 0
fi

for issue in "${issues[@]}"; do echo "$issue"; done
echo "vault-review failed: ${#issues[@]} issue(s) found"
exit 1
