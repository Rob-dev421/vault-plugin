#!/bin/bash
# bin/vault-onboard
# Usage: vault-onboard <vault-root>
# Explains the vault to a new team member from live vault data.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

VAULT_ROOT="${1:-$HOME/vault}"

# Read layer names from vault.json
layers=$(py -3 - "$VAULT_ROOT/vault.json" <<'PYEOF' 2>/dev/null || echo "inbox sources wiki"
import json, sys
d = json.load(open(sys.argv[1]))
layers = d.get('layers', {})
print(layers.get('inbox','inbox'), layers.get('sources','sources'), layers.get('wiki','wiki'))
PYEOF
)
LAYER_INBOX=$(echo "$layers" | cut -d' ' -f1)
LAYER_SOURCES=$(echo "$layers" | cut -d' ' -f2)
LAYER_WIKI=$(echo "$layers" | cut -d' ' -f3)

# Count items
inbox_pending=$(find "$VAULT_ROOT/$LAYER_INBOX" -name "input.md" -exec grep -l "status: pending" {} \; 2>/dev/null | wc -l | tr -d ' ')
source_count=$(find "$VAULT_ROOT/$LAYER_SOURCES" -name "*.md" -not -name "index.md" -not -name "log.md" -not -name "transcript.md" 2>/dev/null | wc -l | tr -d ' ')
wiki_count=$(find "$VAULT_ROOT/$LAYER_WIKI" -name "*.md" -not -name "index.md" -not -name "log.md" 2>/dev/null | wc -l | tr -d ' ')

# Sample one concept from sources if available
sample_concept=$(find "$VAULT_ROOT/$LAYER_SOURCES" -name "*.md" -not -name "index.md" -not -name "log.md" -not -name "transcript.md" 2>/dev/null | head -1)
sample_title=""
if [[ -n "$sample_concept" ]]; then
  sample_title=$(grep "^title:" "$sample_concept" 2>/dev/null | head -1 | sed 's/^title:[ \t]*//')
fi

cat <<EOF
# Vault Onboarding

**Location:** $VAULT_ROOT

## How the vault works

This vault follows the Open Knowledge Format (OKF). Raw inputs flow through
three layers:

  $LAYER_INBOX/   → raw inputs (PDFs, docs, images, notes)
  $LAYER_SOURCES/ → OKF concept files extracted by Claude
  $LAYER_WIKI/    → curated wiki synthesized from sources

## Current state

- Inbox items pending: $inbox_pending
- Source concepts: $source_count
$([ -n "$sample_title" ] && echo "  Example: \"$sample_title\"" || true)
- Wiki entries: $wiki_count

## Skills (daily use)

  vault-ingest    — add a raw file to inbox
  vault-process   — Claude transcribes + extracts concepts (runs automatically after ingest)
  vault-synthesize — Claude writes wiki entries from sources
  vault-validate  — check OKF conformance
  vault-audit     — find stale/orphaned/low-quality items
  vault-status    — quick health summary
  vault-freshness — detect drifted source concepts
  vault-graphify  — build/update knowledge graph (requires graphify)

## Setup for new contributors

1. Install the pre-commit hook (blocks non-conformant commits):

   bash engine/bin/install-hook

   Note: requires Git Bash or WSL on Windows.

2. Run a status check:

   bash engine/bin/vault-status $VAULT_ROOT

3. Read IMPLEMENTATION_PLAN.md for architecture details:

   engine/docs/IMPLEMENTATION_PLAN.md
EOF

# Append graphify section if installed
if command -v graphify &>/dev/null; then
  GRAPH_REPORT="$VAULT_ROOT/graphify-out/GRAPH_REPORT.md"
  cat <<EOF

## Knowledge graph (graphify)

The vault has a queryable knowledge graph in graphify-out/.

  graphify query "<topic>"               — find concept nodes by topic
  graphify path "wiki/X" "sources/Y"    — trace provenance chain
  graphify explain "<concept>"           — focused subgraph
  vault-graphify --full                  — full rebuild (uses LLM API)

$([ -f "$GRAPH_REPORT" ] && echo "Graph report: $GRAPH_REPORT" || echo "No graph yet — run /vault-graphify to build one.")
EOF
fi
